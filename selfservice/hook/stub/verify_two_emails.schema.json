{
  "$id": "verify_two_emails.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Two Email Schema",
  "type": "object",
  "properties": {
    "traits": {
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "ory.sh/kratos": {
            "credentials": { "password": { "identifier": true } },
            "verification": { "via": "email" }
          }
        },
        "recovery_email": {
          "type": "string",
          "format": "email",
          "ory.sh/kratos": {
            "verification": { "via": "email" }
          }
        },
        "name": { "type": "string" }
      },
      "required": ["email"],
      "additionalProperties": false
    }
  }
}
