{
  "$id": "https://example.com/multi-identifier.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Person",
  "type": "object",
  "properties": {
    "traits": {
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "title": "E-Mail",
          "ory.sh/kratos": {
            "credentials": {
              "password": { "identifier": true },
              "passkey":  { "display_name": true }
            }
          }
        },
        "phone": {
          "type": "string",
          "format": "tel",
          "title": "Phone number",
          "ory.sh/kratos": {
            "credentials": {
              "password": { "identifier": true },
              "passkey":  { "display_name": true }
            }
          }
        }
      },
      "required": ["email"]
    }
  },
  "additionalProperties": false
}
